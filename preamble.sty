% Compact enough for a cheatsheet while retaining readable separation.
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.35em plus 0.1em minus 0.1em}
\setlength{\columnsep}{0.55cm}
\setlength{\multicolsep}{0.4em}
\setlength{\premulticols}{0pt}
\setlength{\postmulticols}{0pt}
\raggedcolumns

\setlist{
	leftmargin=*,
	topsep=0.3em,
	itemsep=0.1em,
	parsep=0pt,
	partopsep=0pt
}

\setlength{\abovedisplayskip}{0.45em}
\setlength{\belowdisplayskip}{0.45em}
\setlength{\abovedisplayshortskip}{0.25em}
\setlength{\belowdisplayshortskip}{0.25em}

\titleformat{\section}
	{\large\sffamily\bfseries\color{NavyBlue}}
	{\thesection}{0.45em}{}
\titleformat{\subsection}
	{\normalsize\sffamily\bfseries}
	{\thesubsection}{0.4em}{}
\titleformat{\subsubsection}
	{\normalsize\sffamily\bfseries}
	{\thesubsubsection}{0.4em}{}
\titlespacing*{\section}{0pt}{0.9em}{0.35em}
\titlespacing*{\subsection}{0pt}{0.65em}{0.2em}
\titlespacing*{\subsubsection}{0pt}{0.5em}{0.15em}

\pagestyle{empty}

\newcommand\N{\ensuremath{\mathbb{N}}}
\newcommand\R{\ensuremath{\mathbb{R}}}
\newcommand\Z{\ensuremath{\mathbb{Z}}}
\newcommand\Q{\ensuremath{\mathbb{Q}}}
\newcommand\C{\ensuremath{\mathbb{C}}}
\renewcommand\O{\ensuremath{\emptyset}}
\DeclareMathOperator{\sgn}{sgn}
\newcommand\contra{\scalebox{1.1}{$\lightning$}}

\usepackage{thmtools}
\usepackage[framemethod=TikZ]{mdframed}
\mdfsetup{skipabove=0.5em,skipbelow=0.5em}

\declaretheoremstyle[
	headfont=\bfseries\sffamily\color{ForestGreen!70!black},
	bodyfont=\normalfont,
	mdframed={
		linewidth=2pt,
		rightline=false,
		topline=false,
		bottomline=false,
		linecolor=ForestGreen,
		backgroundcolor=ForestGreen!5
	}
]{thmgreenbox}

\declaretheoremstyle[
	headfont=\bfseries\sffamily\color{NavyBlue!70!black},
	bodyfont=\normalfont,
	mdframed={
		linewidth=2pt,
		rightline=false,
		topline=false,
		bottomline=false,
		linecolor=NavyBlue,
		backgroundcolor=NavyBlue!5
	}
]{thmbluebox}

\declaretheoremstyle[
	headfont=\bfseries\sffamily\color{RawSienna!70!black},
	bodyfont=\normalfont,
	mdframed={
		linewidth=2pt,
		rightline=false,
		topline=false,
		bottomline=false,
		linecolor=RawSienna,
		backgroundcolor=RawSienna!5
	}
]{thmredbox}

\declaretheoremstyle[
	headfont=\bfseries\sffamily\color{RawSienna!70!black},
	bodyfont=\normalfont,
	numbered=no,
	mdframed={
		linewidth=2pt,
		rightline=false,
		topline=false,
		bottomline=false,
		linecolor=RawSienna,
		backgroundcolor=RawSienna!1
	},
	qed=\qedsymbol
]{thmproofbox}

\theoremstyle{definition}
\declaretheorem[style=thmgreenbox,name=Definition]{definition}
\declaretheorem[style=thmbluebox,numbered=no,name=Example]{eg}
\declaretheorem[style=thmredbox,name=Theorem]{theorem}
\declaretheorem[style=thmredbox,name=Proposition]{prop}
\declaretheorem[style=thmredbox,name=Lemma]{lemma}
\declaretheorem[style=thmredbox,numbered=no,name=Corollary]{corollary}
\declaretheorem[style=thmredbox,name=Exercise]{ex}

\declaretheorem[style=thmproofbox,name=Proof]{replacementproof}
\renewenvironment{proof}[1][\proofname]
	{\begin{replacementproof}}
	{\end{replacementproof}}

\declaretheorem[style=thmproofbox,name=Solution,numbered=no]{tmpsolutie}
\newenvironment{solution}[1][]
	{\begin{tmpsolutie}}
	{\end{tmpsolutie}}
